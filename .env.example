# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PostgreSQL (Railway ou outro provider)
DATABASE_URL=postgresql://user:password@host:port/database

# JWT — gere um segredo forte: openssl rand -base64 32
JWT_SECRET=troque_por_um_segredo_forte_em_producao

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@seudominio.com

# Cron job secret (para /api/cron/*)
CRON_SECRET=troque_por_um_segredo_forte

# Criptografia — gere com: openssl rand -hex 32
ENCRYPTION_KEY=troque_por_64_chars_hex_aleatorios
