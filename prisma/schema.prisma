generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Payment {
  id       String @id
  customer String
  email    String
  amount   Int
  status   String
  date     String
  product  String
  method   String

  @@map("payments")
}

model DailySale {
  id       Int    @id @default(autoincrement())
  date     String
  isoDate  String @unique @map("iso_date")
  receita  Int
  vendas   Int
  falhas   Int

  @@map("daily_sales")
}

model Product {
  id               String   @id
  name             String
  description      String   @default("")
  imageUrl         String   @default("") @map("image_url")
  price            Int
  interval         String
  sales            Int
  revenue          BigInt
  status           String
  stripeId         String   @map("stripe_id")
  slug             String?  @unique
  currency         String   @default("EUR")
  defaultShipping  Int      @default(0) @map("default_shipping")
  paymentMethods   Json     @default("[]") @map("payment_methods")
  shippingOptions  Json     @default("[]") @map("shipping_options")
  orderBumps       Json     @default("[]") @map("order_bumps")
  reviews          Json     @default("[]")
  showReviews      Boolean  @default(false) @map("show_reviews")
  checkoutTemplate String   @default("single_step") @map("checkout_template")
  checkoutLanguage String   @default("pt") @map("checkout_language")
  requirePhone     Boolean  @default(false) @map("require_phone")
  requireAddress   Boolean  @default(false) @map("require_address")
  logoUrl          String   @default("") @map("logo_url")
  brandName        String   @default("") @map("brand_name")
  successUrl       String   @default("") @map("success_url")
  metaPixelId      String   @default("") @map("meta_pixel_id")
  utmfyApiToken    String   @default("") @map("utmfy_api_token")
  userId           String   @default("") @map("user_id")
  checkoutPayments CheckoutPayment[]

  @@map("products")
}

model CheckoutPayment {
  id                    String   @id @default(cuid())
  productId             String   @map("product_id")
  status                String   @default("pending")
  amount                Int
  currency              String   @default("EUR")
  stripePaymentIntentId String?  @unique @map("stripe_payment_intent_id")
  customerName          String   @default("") @map("customer_name")
  customerEmail         String   @default("") @map("customer_email")
  customerPhone         String   @default("") @map("customer_phone")
  metadata              Json     @default("{}")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  product               Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("checkout_payments")
}

model PixelConfig {
  id              String       @id
  platform        String
  name            String
  pixelId         String       @map("pixel_id")
  accessToken     String       @map("access_token")
  testEventCode   String       @map("test_event_code")
  conversionLabel String       @map("conversion_label")
  enabled         Boolean
  events          Json
  createdAt       DateTime     @map("created_at")
  updatedAt       DateTime     @map("updated_at")
  logs            PixelLog[]

  @@map("pixel_configs")
}

model PixelLog {
  id        String      @id
  configId  String      @map("config_id")
  platform  String
  event     String
  success   Boolean
  message   String
  timestamp DateTime
  data      Json?
  isTest    Boolean     @default(false) @map("is_test")
  config    PixelConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@map("pixel_logs")
}

model Settings {
  id           Int     @id @default(1)
  companyName  String  @default("") @map("company_name")
  nif          String  @default("") @map("nif")
  email        String  @default("") @map("email")
  timezone     String  @default("Europe/Lisbon") @map("timezone")
  stripeKey    String  @default("") @map("stripe_key")
  stripeSecret String  @default("") @map("stripe_secret")
  webhookSecret String @default("") @map("webhook_secret")
  notifyApproved  Boolean @default(true)  @map("notify_approved")
  notifyFailed    Boolean @default(true)  @map("notify_failed")
  notifyRefund    Boolean @default(false) @map("notify_refund")
  notifyDaily     Boolean @default(false) @map("notify_daily")
  notifyWeekly    Boolean @default(false) @map("notify_weekly")

  @@map("settings")
}
