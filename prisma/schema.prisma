generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Payment {
  id               String   @id
  customer         String
  email            String
  amount           Int
  status           String
  date             String
  createdAt        DateTime @default(now()) @map("created_at")
  product          String
  method           String
  cardLast4        String   @default("") @map("card_last4")
  cardBrand        String   @default("") @map("card_brand")
  cardCountry      String   @default("") @map("card_country")
  riskLevel        String   @default("") @map("risk_level")
  riskScore        Int      @default(0) @map("risk_score")
  fee              Int      @default(0)
  net              Int      @default(0)
  stripeCustomerId String   @default("") @map("stripe_customer_id")
  balanceTxId      String   @default("") @map("balance_tx_id")
  refundedAmount   Int      @default(0) @map("refunded_amount")

  @@map("payments")
}

model DailySale {
  id       Int    @id @default(autoincrement())
  date     String
  isoDate  String @unique @map("iso_date")
  receita  Int
  vendas   Int
  falhas   Int

  @@map("daily_sales")
}

model Product {
  id               String   @id
  name             String
  description      String   @default("")
  imageUrl         String   @default("") @map("image_url")
  price            Int
  interval         String
  sales            Int
  revenue          BigInt
  status           String
  stripeId         String   @map("stripe_id")
  slug             String?  @unique
  currency         String   @default("EUR")
  createdAt        DateTime @default(now()) @map("created_at")
  defaultShipping  Int      @default(0) @map("default_shipping")
  paymentMethods   Json     @default("[]") @map("payment_methods")
  shippingOptions  Json     @default("[]") @map("shipping_options")
  orderBumps       Json     @default("[]") @map("order_bumps")
  reviews          Json     @default("[]")
  showReviews      Boolean  @default(false) @map("show_reviews")
  checkoutTemplate String   @default("single_step") @map("checkout_template")
  checkoutLanguage String   @default("pt") @map("checkout_language")
  requirePhone     Boolean  @default(false) @map("require_phone")
  requireAddress   Boolean  @default(false) @map("require_address")
  logoUrl          String   @default("") @map("logo_url")
  brandName        String   @default("") @map("brand_name")
  legalName        String   @default("") @map("legal_name")
  successUrl       String   @default("") @map("success_url")
  metaPixelId      String   @default("") @map("meta_pixel_id")
  utmfyApiToken    String   @default("") @map("utmfy_api_token")
  userId           String   @default("") @map("user_id")
  active           Boolean  @default(true)
  countdownMinutes Int      @default(15) @map("countdown_minutes")
  stock            Int      @default(-1)
  pixelIds         Json     @default("[]") @map("pixel_ids")
  customDomain     String   @default("") @map("custom_domain")
  utmifyConfigId   String?  @map("utmify_config_id")
  utmifyConfig     UtmifyConfig? @relation("ProductUtmify", fields: [utmifyConfigId], references: [id], onDelete: SetNull)
  checkoutPayments CheckoutPayment[]
  cartItems        CartItem[]

  @@map("products")
}

model CheckoutPayment {
  id                    String   @id @default(cuid())
  productId             String   @map("product_id")
  status                String   @default("pending")
  amount                Int
  currency              String   @default("EUR")
  stripePaymentIntentId String?  @unique @map("stripe_payment_intent_id")
  stripeChargeId        String   @default("") @map("stripe_charge_id")
  stripeErrorCode       String   @default("") @map("stripe_error_code")
  stripeErrorMsg        String   @default("") @map("stripe_error_msg")
  refundedAmount        Int      @default(0) @map("refunded_amount")
  disputeId             String   @default("") @map("dispute_id")
  disputeStatus         String   @default("") @map("dispute_status")
  lastStripeEventId     String   @default("") @map("last_stripe_event_id")
  isAbandoned           Boolean  @default(false) @map("is_abandoned")
  upsellStatus          String   @default("none") @map("upsell_status")
  upsellAmount          Int      @default(0) @map("upsell_amount")
  upsellPiId            String   @default("") @map("upsell_pi_id")
  stripeCustomerId      String   @default("") @map("stripe_customer_id")
  cardLast4             String   @default("") @map("card_last4")
  cardBrand             String   @default("") @map("card_brand")
  cardCountry           String   @default("") @map("card_country")
  riskLevel             String   @default("") @map("risk_level")
  fee                   Int      @default(0)
  net                   Int      @default(0)
  balanceTxId           String   @default("") @map("balance_tx_id")
  customerName          String   @default("") @map("customer_name")
  customerEmail         String   @default("") @map("customer_email")
  customerPhone         String   @default("") @map("customer_phone")
  paymentMethod         String   @default("") @map("payment_method")
  addressLine1          String   @default("") @map("address_line1")
  addressLine2          String   @default("") @map("address_line2")
  addressCity           String   @default("") @map("address_city")
  addressPostalCode     String   @default("") @map("address_postal_code")
  addressCountry        String   @default("") @map("address_country")
  urlParams             Json     @default("{}") @map("url_params")
  metadata              Json     @default("{}")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  product               Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("checkout_payments")
}

model PixelConfig {
  id              String     @id @default(cuid())
  userId          String     @default("") @map("user_id")
  platform        String
  name            String     @default("")
  pixelId         String     @default("") @map("pixel_id")
  accessToken     String     @default("") @map("access_token")
  testEventCode   String     @default("") @map("test_event_code")
  conversionLabel String     @default("") @map("conversion_label")
  enabled         Boolean    @default(true)
  events          Json       @default("[]")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  logs            PixelLog[]

  @@map("pixel_configs")
}

model PixelLog {
  id        String      @id @default(cuid())
  userId    String      @default("") @map("user_id")
  configId  String      @map("config_id")
  platform  String
  event     String
  success   Boolean
  message   String
  timestamp DateTime    @default(now())
  data      Json?
  isTest    Boolean     @default(false) @map("is_test")
  config    PixelConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@map("pixel_logs")
}

model Settings {
  id           Int     @id @default(1)
  companyName  String  @default("") @map("company_name")
  nif          String  @default("") @map("nif")
  email        String  @default("") @map("email")
  timezone     String  @default("Europe/Lisbon") @map("timezone")
  stripeKey    String  @default("") @map("stripe_key")
  stripeSecret String  @default("") @map("stripe_secret")
  webhookSecret String @default("") @map("webhook_secret")
  notifyApproved      Boolean @default(true)  @map("notify_approved")
  notifyFailed        Boolean @default(true)  @map("notify_failed")
  notifyRefund        Boolean @default(false) @map("notify_refund")
  notifyDaily         Boolean @default(false) @map("notify_daily")
  notifyWeekly        Boolean @default(false) @map("notify_weekly")

  @@map("settings")
}

model PushcutConfig {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  name       String   @default("")
  webhookUrl String   @default("") @map("webhook_url")
  events     Json     @default("[]")
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("pushcut_configs")
}

model UtmifyConfig {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  name      String    @default("")
  apiToken  String    @default("") @map("api_token")
  enabled   Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  products  Product[] @relation("ProductUtmify")

  @@map("utmify_configs")
}

model OutboundWebhook {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  name       String
  url        String
  secret     String
  events     Json     @default("[]")
  productIds Json     @default("[]") @map("product_ids")
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("outbound_webhooks")
}

model StripeEvent {
  id         String   @id
  type       String
  livemode   Boolean  @default(false)
  apiVersion String   @default("") @map("api_version")
  objectId   String   @default("") @map("object_id")
  objectType String   @default("") @map("object_type")
  payload    Json
  processed  Boolean  @default(false)
  error      String?
  receivedAt DateTime @default(now()) @map("received_at")

  @@map("stripe_events")
}

model AbandonedCart {
  id                    String    @id @default(cuid())
  productId             String    @map("product_id")
  stripePaymentIntentId String    @unique @map("stripe_payment_intent_id")
  customerName          String    @default("") @map("customer_name")
  customerEmail         String    @default("") @map("customer_email")
  customerPhone         String    @default("") @map("customer_phone")
  amount                Int
  currency              String    @default("EUR")
  urlParams             Json      @default("{}") @map("url_params")
  bumpIds               Json      @default("[]") @map("bump_ids")
  shippingId            String    @default("") @map("shipping_id")
  status                String    @default("pending")
  recoveredAt           DateTime? @map("recovered_at")
  expiresAt             DateTime  @map("expires_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@map("abandoned_carts")
}

model StripeApiLog {
  id         String   @id @default(cuid())
  operation  String
  objectId   String   @default("") @map("object_id")
  request    Json     @default("{}")
  response   Json     @default("{}")
  success    Boolean
  errorCode  String?  @map("error_code")
  errorMsg   String?  @map("error_msg")
  durationMs Int      @default(0) @map("duration_ms")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("stripe_api_logs")
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  name      String    @default("")
  key       String    @unique
  keyPrefix String    @map("key_prefix")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  @@map("api_keys")
}

model Cart {
  id              String     @id @default(cuid())
  userId          String     @map("user_id")
  status          String     @default("pending")
  expiresAt       DateTime   @map("expires_at")
  stripeSessionId String?    @unique @map("stripe_session_id")
  customerName    String     @default("") @map("customer_name")
  customerEmail   String     @default("") @map("customer_email")
  customerPhone   String     @default("") @map("customer_phone")
  urlParams       Json       @default("{}") @map("url_params")
  metadata        Json       @default("{}")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  items           CartItem[]
  order           Order?

  @@map("carts")
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String  @map("cart_id")
  productId String  @map("product_id")
  quantity  Int     @default(1)
  unitPrice Int     @map("unit_price")
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("cart_items")
}

model Order {
  id                    String      @id @default(cuid())
  cartId                String      @unique @map("cart_id")
  userId                String      @map("user_id")
  status                String      @default("pending")
  amount                Int
  currency              String      @default("EUR")
  stripeSessionId       String?     @unique @map("stripe_session_id")
  stripePaymentIntentId String?     @map("stripe_payment_intent_id")
  customerName          String      @default("") @map("customer_name")
  customerEmail         String      @default("") @map("customer_email")
  customerPhone         String      @default("") @map("customer_phone")
  paymentMethod         String      @default("") @map("payment_method")
  urlParams             Json        @default("{}") @map("url_params")
  metadata              Json        @default("{}")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")
  cart                  Cart        @relation(fields: [cartId], references: [id])
  items                 OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String @map("order_id")
  productId String @map("product_id")
  name      String
  quantity  Int
  unitPrice Int    @map("unit_price")
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model CustomDomain {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  domain     String    @unique
  status     String    @default("pending") // pending | active | failed
  failReason String    @default("") @map("fail_reason")
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("custom_domains")
}

model Funnel {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  name         String
  productId    String   @map("product_id")
  upsellId     String   @map("upsell_id")
  upsellPrice  Int      @default(0) @map("upsell_price")
  upsellTitle  String   @default("") @map("upsell_title")
  upsellDesc   String   @default("") @map("upsell_desc")
  upsellImage  String   @default("") @map("upsell_image")
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("funnels")
}

model StripeBalance {
  id        Int      @id @default(1)
  available Int      @default(0)
  pending   Int      @default(0)
  currency  String   @default("EUR")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("stripe_balance")
}

model StripeCustomer {
  id               String   @id
  userId           String   @default("") @map("user_id")
  name             String   @default("")
  email            String   @default("")
  phone            String   @default("")
  stripeCustomerId String   @unique @map("stripe_customer_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("stripe_customers")
}

model Payout {
  id          String   @id
  amount      Int
  currency    String   @default("EUR")
  status      String
  arrivalDate DateTime @map("arrival_date")
  description String   @default("")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("payouts")
}

model FraudWarning {
  id              String   @id
  paymentIntentId String   @default("") @map("payment_intent_id")
  chargeId        String   @default("") @map("charge_id")
  fraudType       String   @default("") @map("fraud_type")
  actionable      Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("fraud_warnings")
}

model StripeDispute {
  id              String   @id
  chargeId        String   @default("") @map("charge_id")
  paymentIntentId String   @default("") @map("payment_intent_id")
  amount          Int      @default(0)
  currency        String   @default("EUR")
  status          String   @default("")
  reason          String   @default("")
  evidenceDueBy   DateTime? @map("evidence_due_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("stripe_disputes")
}

model StripeRefund {
  id              String   @id
  chargeId        String   @default("") @map("charge_id")
  paymentIntentId String   @default("") @map("payment_intent_id")
  amount          Int      @default(0)
  currency        String   @default("EUR")
  status          String   @default("")
  reason          String   @default("")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("stripe_refunds")
}

model StripeCoupon {
  id               String   @id
  name             String   @default("")
  amountOff        Int?     @map("amount_off")
  percentOff       Float?   @map("percent_off")
  currency         String   @default("")
  duration         String   @default("")
  durationMonths   Int?     @map("duration_months")
  maxRedemptions   Int?     @map("max_redemptions")
  timesRedeemed    Int      @default(0) @map("times_redeemed")
  valid            Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("stripe_coupons")
}

model StripePromoCode {
  id            String   @id
  couponId      String   @map("coupon_id")
  code          String   @unique
  active        Boolean  @default(true)
  timesRedeemed Int      @default(0) @map("times_redeemed")
  maxRedemptions Int?    @map("max_redemptions")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("stripe_promo_codes")
}

model StripeBalanceTransaction {
  id          String   @id
  type        String
  amount      Int
  fee         Int      @default(0)
  net         Int      @default(0)
  currency    String   @default("EUR")
  status      String   @default("")
  description String   @default("")
  createdAt   DateTime @map("created_at")
  syncedAt    DateTime @default(now()) @map("synced_at")

  @@map("stripe_balance_transactions")
}
